rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // --- Validation Helpers ---
    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.userId == request.auth.uid &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isValidRevenue(data) {
      return data.userId == request.auth.uid &&
             data.companyId is string &&
             (data.revenue is number || data.revenue is string) &&
             (data.createdAt == request.time || !data.keys().has('createdAt'));
    }

    function isValidDetailedEntry(data) {
      return data.userId == request.auth.uid &&
             data.companyId is string &&
             data.month is string &&
             (data.date == request.time || !data.keys().has('date'));
    }

    function isValidBackup(data) {
      return data.userId == request.auth.uid &&
             data.type is string &&
             data.payload is string;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.companyId is string;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid &&
             data.companyId is string &&
             data.name is string &&
             data.type in ['income', 'expense'] &&
             data.date is timestamp;
    }

    // --- Collections ---
    match /companies/{companyId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCompany(incoming());
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    match /revenues/{revenueId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidRevenue(incoming());
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    match /detailed_entries/{entryId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidDetailedEntry(incoming());
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    match /backups/{backupId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBackup(incoming());
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    match /goals/{goalId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidGoal(incoming());
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }
  }
}
